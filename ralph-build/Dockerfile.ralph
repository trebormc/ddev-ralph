#ddev-generated
# Ralph Loop container — lightweight autonomous task orchestrator
# Only bash, jq, and SSH client. AI tools and Beads run in their own containers.

FROM ubuntu:24.04

ARG USERNAME=ralph
ARG USER_UID=1000
ARG USER_GID=1000

ENV DEBIAN_FRONTEND=noninteractive
ENV USERNAME=${USERNAME}
ENV USER_HOME=/home/${USERNAME}

# Install only what Ralph needs: bash, jq, git, SSH client
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    ca-certificates \
    gnupg \
    sudo \
    jq \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

# Install bd wrapper — delegates to Beads container via SSH
RUN printf '#!/bin/bash\nexec ssh beads bd "$@"\n' > /usr/local/bin/bd \
    && chmod +x /usr/local/bin/bd

# Create user with matching UID/GID
RUN existing_user=$(getent passwd ${USER_UID} | cut -d: -f1) \
    && existing_group=$(getent group ${USER_GID} | cut -d: -f1) \
    && if [ -n "$existing_user" ] && [ "$existing_user" != "${USERNAME}" ]; then \
         userdel -r $existing_user 2>/dev/null || true; \
       fi \
    && if [ -n "$existing_group" ] && [ "$existing_group" != "${USERNAME}" ]; then \
         groupdel $existing_group 2>/dev/null || true; \
       fi \
    && groupadd --gid ${USER_GID} ${USERNAME} 2>/dev/null || true \
    && useradd --uid ${USER_UID} --gid ${USER_GID} -m -s /bin/bash ${USERNAME} 2>/dev/null || true \
    && echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers.d/${USERNAME} \
    && chmod 0440 /etc/sudoers.d/${USERNAME} \
    && passwd -d ${USERNAME}

# Set up SSH client config
RUN mkdir -p ${USER_HOME}/.ssh && chmod 700 ${USER_HOME}/.ssh
COPY ralph-build/ssh-config ${USER_HOME}/.ssh/config
RUN chmod 600 ${USER_HOME}/.ssh/config \
    && chown -R ${USER_UID}:${USER_GID} ${USER_HOME}/.ssh

RUN mkdir -p /var/www/html \
    && chown -R ${USER_UID}:${USER_GID} ${USER_HOME} \
    && chown -R ${USER_UID}:${USER_GID} /var/www/html

USER ${USERNAME}
WORKDIR ${USER_HOME}

RUN echo 'alias ll="ls -la"' >> ~/.bashrc \
    && echo '' >> ~/.bashrc \
    && echo 'echo "Ralph container ready (orchestrator)"' >> ~/.bashrc \
    && echo 'echo "  AI backends via SSH: opencode | claude-code"' >> ~/.bashrc \
    && echo 'echo "  Usage: ralph.sh --backend opencode|claude [options]"' >> ~/.bashrc

COPY ralph-build/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN sudo chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

WORKDIR /var/www/html
